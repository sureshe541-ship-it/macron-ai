# Replit Deployment Configuration
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=gpt-4
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://*.replit.dev,*
FRONTEND_URL=https://${REPLIT_OWNER}-${REPLIT_SLUG}.replit.dev
NODE_ENV=production
VITE_API_URL=https://${REPLIT_OWNER}-${REPLIT_SLUG}.replit.dev/api
